# Copy to .env.local and fill in your Supabase project values.
# Without these, KudoLoop runs in local mock mode (no network) — which is how
# the evaluation build behaves.

# Project URL, e.g. https://abcdefgh.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# Public anon key (safe to ship; real protection comes from Row Level Security)
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Private Storage bucket for proof images (created by migration 0002)
EXPO_PUBLIC_SUPABASE_PROOF_BUCKET=proofs
